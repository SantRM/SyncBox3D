# ─────────── Base de datos ───────────
POSTGRES_DB=syncbox
POSTGRES_USER=syncbox
POSTGRES_PASSWORD=cambia_esto_en_local
# En servidor, mantener en 127.0.0.1 salvo que exista una razon operativa
# concreta para exponer Postgres a la red.
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432

# ─────────── Backend ───────────
APP_ENV=dev
# En servidor, mantener en 127.0.0.1: el frontend proxy interno atiende /api.
BACKEND_BIND_ADDRESS=127.0.0.1
APP_PORT=8080
# JWT_SECRET: generar con `openssl rand -hex 32` (mín. 32 bytes hex)
JWT_SECRET=reemplaza_por_un_secreto_de_al_menos_32_bytes_hex_aqui
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_HOURS=168
JWT_ISSUER=syncbox
JWT_AUDIENCE=syncbox-app
LOGIN_MAX_FAILS=5
LOGIN_BLOCK_MIN=15
# El backend acepta varios orígenes separados por coma. Dejamos el del
# frontend dockerizado (NGINX) y el de Vite (npm run dev) por defecto.
CORS_ORIGIN=http://localhost:8081,http://localhost:5173
LOG_LEVEL=info
MODEL_MAX_MB=500

# Ruta del host usada solo con docker-compose.proxmox.yml.
# En Proxmox/servidor debe apuntar a una carpeta persistente con espacio amplio.
# Ejemplo Linux: /srv/syncbox/recursos
RESOURCE_HOST_PATH=/srv/syncbox/recursos

# ─────────── Frontend ───────────
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=8081
